{
  "name": "tiki-v2",
  "version": "0.5.4",
  "private": true,
  "description": "GitHub-issue-centric workflow framework for Claude Code",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm test:ts && pnpm test:rust",
    "test:ts": "pnpm -C packages/shared test && pnpm -C apps/desktop test",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "version-bump": "node scripts/version-bump.mjs"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
