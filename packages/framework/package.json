{
  "name": "@tiki/framework",
  "version": "0.1.0",
  "description": "Claude Code commands for Tiki workflow framework",
  "type": "module",
  "main": "./install.js",
  "bin": {
    "tiki-install": "./install.js",
    "tiki-state": "./scripts/state.mjs"
  },
  "files": [
    "commands",
    "install.js",
    "scripts"
  ],
  "scripts": {
    "install-commands": "node install.js",
    "state": "node ./scripts/state.mjs",
    "test": "node --test __tests__/*.test.mjs"
  },
  "dependencies": {
    "@tiki/shared": "workspace:*"
  }
}
